# herVoice backend — copy to .env and fill in values

# Server
HERVOICE_HOST=0.0.0.0
HERVOICE_PORT=8765

# STT — faster-whisper
WHISPER_MODEL=medium          # tiny/base/small/medium/large-v3
WHISPER_DEVICE=cpu            # cpu or cuda
WHISPER_COMPUTE=int8          # int8 / float16 / float32
WHISPER_LANGUAGE=             # leave blank for auto-detect (Slovak+English)
WHISPER_INITIAL_PROMPT=       # optional prompt to bias transcription

# LLM — OpenClaw / OpenAI-compatible endpoint
OPENCLAW_BASE_URL=http://192.168.1.35:11434/v1
OPENCLAW_API_KEY=nocreds
OPENCLAW_MODEL=qwen2.5:3b
OPENCLAW_SYSTEM_PROMPT=You are a helpful voice assistant. Keep your responses short and natural for speech.
LLM_MAX_TOKENS=256
LLM_TEMPERATURE=0.7

# TTS — Piper
PIPER_BINARY=/usr/local/bin/piper
PIPER_MODEL=/usr/share/piper/voices/sk_SK-lili-medium.onnx
PIPER_SAMPLE_RATE=16000
